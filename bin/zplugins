#!/usr/bin/env zsh # -*- mode: sh; eval: (sh-set-shell "zsh") -*-

CMD_NAME=${0:t}

usage() {
    local cmd="${1}"

    echo
    echo "Usage: ${CMD_NAME} COMMAND OPTIONS"
    echo
    echo "Commands:"
    echo
    echo "help"
    echo "list"
}

cmd_list() {

    @zplugins_loaded_plugin_names

    local name_str="$(@zplugins_loaded_plugin_names)"
    local -a names=( "${(z)name_str}" )

    for name in ${(o)names[@]}; do
        local brief="$(@zplugins_short_description ${name})"
        if [[ -n "${brief}" ]]; then
            brief=": ${brief}"
        fi

        local version="$(@zplugins_plugin_version ${name})"
        if [[ -n "${version}" ]]; then
            version=" (${version})"
        fi

        printf '%s%s%s\n' ${name} ${brief} ${version}
    done
}

main() {
    local cmd=''
    local args=()

    while [ "$#" -gt 0 ]; do
        case "${1}" in
            list)
                cmd=list
                ;;
            -h|--help|help)
                usage ${cmd}
                exit 0
                ;;
            *)
                printf 'Error: unknown command/parameter s' "${1}" >&2
                usage
                exit 1
                ;;
        esac
        shift 1
    done
    if [[ -z "${cmd}" ]]; then
        printf 'Error: no command specified' >&2
        usage
        exit 1
    fi
    cmd_${cmd} ${args[*]}
}

main $*
